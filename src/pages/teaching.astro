---
import Base from "../layouts/Base.astro";
import yaml from "js-yaml";
import raw from "../data/teaching.yaml?raw";

const data = yaml.load(raw) as any;
const courses = data.courses ?? [];
const supervision = data.supervision ?? [];
---

<Base
  title="Teaching"
  description="Courses taught across undergraduate, MBA, EMBA, and graduate programs, and graduate student supervision by Shamel Addas."
>
  <h1>Teaching</h1>

  <section class="section">
    <h2>Courses Taught</h2>
    {
      courses.map((g: any) => (
        <div class="table-wrap">
          <table class="cv">
            <caption>{g.group}</caption>
            <thead>
              <tr>
                <th>Course</th>
                <th>Years</th>
                <th>Type</th>
                <th>Program</th>
                <th>Institution</th>
              </tr>
            </thead>
            <tbody>
              {g.items.map((c: any) => (
                <tr>
                  <td>{c.number ? `${c.number}: ` : ""}{c.title}</td>
                  <td>{c.years}</td>
                  <td>{c.type}</td>
                  <td>{c.program}</td>
                  <td>{c.institution}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ))
    }
  </section>

  <section class="section">
    <h2>Graduate Student Supervision</h2>
    {
      supervision.map((g: any) => (
        <Fragment>
          <h3>{g.group}</h3>
          <ul class="supervision-list">
            {g.items.map((s: any) => (
              <li>
                <span class="stud">{s.student}</span>
                {s.role ? <span class="role"> &middot; {s.role}</span> : null}
                <div class="meta">{s.title} ({s.years})</div>
              </li>
            ))}
          </ul>
        </Fragment>
      ))
    }
  </section>
</Base>
