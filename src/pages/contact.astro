---
import Base from "../layouts/Base.astro";

// To make the contact form deliver mail: create a free access key at
// https://web3forms.com (enter the destination email, copy the key) and paste
// it below. Until then the form renders but will not send.
const WEB3FORMS_ACCESS_KEY = "YOUR_WEB3FORMS_ACCESS_KEY";
---

<Base
  title="Contact"
  description="Contact information for Shamel Addas, Smith School of Business, Queen's University, Kingston, Ontario."
>
  <h1>Contact</h1>

  <div class="contact contact-grid">
    <div>
      <dl>
        <dt>Email</dt>
        <dd><a href="mailto:shamel.addas@queensu.ca">shamel.addas@queensu.ca</a></dd>

        <dt>Phone</dt>
        <dd>(613) 533-3287</dd>

        <dt>Office</dt>
        <dd>
          Smith School of Business<br />
          Queen's University<br />
          143 Union Street W.<br />
          Kingston, Ontario K7L 2P3<br />
          Canada
        </dd>

        <dt>Online</dt>
        <dd>
          <a href="https://www.linkedin.com/in/shameladdas/" target="_blank" rel="noopener">LinkedIn</a>
        </dd>
      </dl>
    </div>

    <div>
      <h2>Send a Message</h2>
      <form action="https://api.web3forms.com/submit" method="POST">
        <input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} />
        <input type="hidden" name="subject" value="New message from shameladdas.net" />
        <input type="hidden" name="from_name" value="shameladdas.net contact form" />
        <!-- honeypot: bots fill this, humans do not -->
        <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off" />

        <div class="form-field">
          <label for="name">Name</label>
          <input id="name" type="text" name="name" required />
        </div>
        <div class="form-field">
          <label for="email">Email</label>
          <input id="email" type="email" name="email" required />
        </div>
        <div class="form-field">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="5" required></textarea>
        </div>
        <button class="submit" type="submit">Send</button>
      </form>
      {
        WEB3FORMS_ACCESS_KEY === "YOUR_WEB3FORMS_ACCESS_KEY" && (
          <p class="meta" style="color:var(--muted);font-size:0.85rem;margin-top:0.75rem;">
            Setup note: add a free Web3Forms access key in <code>src/pages/contact.astro</code> to enable
            delivery.
          </p>
        )
      }
    </div>
  </div>
</Base>
